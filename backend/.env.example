PORT=3001
API_VERSION=v1
NODE_ENV=development

# Required in production (app refuses to boot without it when NODE_ENV=production)
JWT_SECRET=change-me-to-a-long-random-string

# Paste your real Postgres password after the colon
DATABASE_URL=postgresql://postgres:YOUR_PASSWORD@localhost:5432/dashzw

# Product images: local disk (default) → backend/uploads/ served at /uploads/
# STORAGE_PROVIDER=local
