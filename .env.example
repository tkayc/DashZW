# DashZW environment configuration
# Copy to .env and adjust for your environment.

# API
PORT=3001
API_VERSION=v1
JWT_SECRET=change-me-in-production
CORS_ORIGINS=http://localhost:5173,http://localhost:5174,http://localhost:5175,http://localhost:5176
LOG_REQUESTS=0

# Frontends (Vite)
VITE_API_URL=http://localhost:3001

# Placeholders for production services
# DATABASE_URL=postgresql://user:pass@localhost:5432/dashzw
# REDIS_URL=redis://localhost:6379
# S3_BUCKET=
# MAPS_API_KEY=
# SENTRY_DSN=
# SMTP_URL=
# SMS_PROVIDER_KEY=
# PUSH_VAPID_PUBLIC=
# PUSH_VAPID_PRIVATE=
